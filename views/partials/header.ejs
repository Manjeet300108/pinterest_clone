<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pinterest Clone</title>

  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

  <% if(nav===true){ %>

    <div class="w-full bg-zinc-900 text-white shadow-md">

      <div class="max-w-7xl mx-auto px-4 md:px-8 py-3 flex flex-col gap-3">

        <!-- TOP -->
        <div class="flex flex-col md:flex-row items-center justify-between gap-3">

          <!-- Logo -->
          <a href="/profile" class="text-xl md:text-2xl font-bold text-red-500">
            Pinterest
          </a>

          <!-- Search -->
          <form action="/search" method="GET" class="flex items-center w-full md:w-auto max-w-md">

            <input type="text" name="username" placeholder="Search user..."
              class="w-full px-4 py-1.5 rounded-l-full bg-white text-black text-sm outline-none" autocomplete="off"
              required>

            <button class="bg-white px-4 py-1.5 rounded-r-full text-black hover:bg-gray-200">
              <i class="ri-search-line"></i>
            </button>

          </form>

          <!-- Links (FIXED ALIGNMENT) -->
          <div class="flex flex-wrap items-center justify-center md:justify-end gap-4 text-sm md:text-base">

            <a href="/profile" class="hover:text-red-400 transition">
              Profile
            </a>

            <a href="/feed" class="hover:text-red-400 transition">
              Feed
            </a>

            <a href="/add"
              class="px-3 py-1 rounded-full bg-gradient-to-r from-pink-500 to-red-500 text-white shadow-md hover:scale-105 hover:shadow-lg transition">
              Create Pin ⭐
            </a>

            <a href="/logout"
              class="px-3 py-1 bg-red-600 text-white rounded-full hover:scale-105 hover:shadow-lg transition">
              Logout
            </a>

          </div>

        </div>

        <!-- ERROR -->
        <% if (error && error.length> 0) { %>
          <p class="text-red-400 text-xs text-center">
            <%= error[0] %>
          </p>
          <% } %>

      </div>

    </div>

    <% } %>