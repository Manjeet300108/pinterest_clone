<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pinterest Clone</title>

  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

<% if(nav===true){ %>

<div class="w-full bg-zinc-900 text-white shadow-md">

  <div class="max-w-7xl mx-auto px-4 md:px-8 py-3 flex flex-col gap-2">

    <div class="flex items-center justify-between gap-4">

      <!-- 🔴 Logo -->
      <a href="/profile" class="text-xl md:text-2xl font-bold tracking-wide text-red-500">
        Pinterest
      </a>

      <!-- 🔍 SEARCH BAR -->
      <form action="/search" method="GET" class="flex items-center flex-1 max-w-md mx-4">
        <input 
          type="text" 
          name="username"
          placeholder="Search user..."
          class="w-full px-4 py-1.5 rounded-l-full bg-white text-black text-sm outline-none placeholder-gray-500"
          autocomplete="off"
          required
        >
        <button class="bg-white px-4 py-1.5 rounded-r-full text-black text-sm hover:bg-gray-200 transition">
          <i class="ri-search-line"></i>
        </button>
      </form>

      <!-- 📱 Nav Links -->
      <div class="flex items-center gap-4 md:gap-6 text-sm md:text-base">

        <a href="/profile" class="hover:text-red-400 transition">
          Profile
        </a>

        <a href="/feed" class="hover:text-red-400 transition">
          Feed
        </a>

        <a href="/add"
           class="px-4 py-1.5 border border-red-500 text-red-400 rounded-full hover:bg-red-500 hover:text-white transition text-xs md:text-sm">
          + Post
        </a>

        <a href="/logout"
           class="px-4 py-1.5 bg-red-600 hover:bg-red-700 rounded-full text-xs md:text-sm font-semibold transition">
          Logout
        </a>

      </div>

    </div>

    <!-- 🔥 ERROR MESSAGE (STEP 2) -->
    <% if (error && error.length > 0) { %>
      <p class="text-red-400 text-xs ml-[120px] md:ml-[160px]">
        <%= error[0] %>
      </p>
    <% } %>

  </div>

</div>

<% } %>