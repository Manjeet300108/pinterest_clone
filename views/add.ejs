<% include ./partials/header.ejs %>

    <div class="w-full min-h-screen bg-zinc-900 flex items-center justify-center px-4 py-10">

        <div class="w-full max-w-lg bg-white rounded-2xl shadow-2xl p-6">

            <h1 class="text-2xl font-bold text-center text-zinc-800">
                Create New Post 📌
            </h1>

            <form id="postForm" action="/createpost" method="POST" enctype="multipart/form-data" class="mt-6 space-y-4">

                <!-- Image Upload -->
                <label
                    class="block border-2 border-dashed border-zinc-300 rounded-xl p-6 text-center cursor-pointer hover:border-red-400 transition">
                    <span class="text-sm text-zinc-500">Click to upload image</span>
                    <input id="imageInput" type="file" name="postimage" class="hidden" required>
                </label>

                <!-- Image Preview -->
                <img id="preview" class="hidden w-full h-48 object-cover rounded-lg" />

                <!-- Title -->
                <input id="title" type="text" name="title" placeholder="Enter title..."
                    class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
                    required>

                <!-- Description -->
                <textarea name="description" placeholder="Write description..."
                    class="w-full px-4 py-2 border rounded-lg h-28 resize-none focus:outline-none focus:ring-2 focus:ring-red-400"></textarea>

                <!-- Error Message -->
                <p id="errorMsg" class="text-red-500 text-sm hidden"></p>

                <!-- Submit -->
                <button id="submitBtn" type="submit"
                    class="w-full bg-red-600 hover:bg-red-700 text-white py-2 rounded-lg font-semibold transition">
                    Create Post 🚀
                </button>

            </form>

        </div>

    </div>
    
    
    <% include ./partials/footer.ejs %>
    <script src="/javascripts/add.js"></script>