<% include ./partials/header.ejs %>

    <div class="w-full min-h-screen bg-zinc-900 flex items-center justify-center px-4 py-10">

        <div class="bg-white rounded-2xl shadow-xl p-6 max-w-2xl w-full">

            <!-- Image Container -->
            <div class="relative">

                <!-- ❌ CLOSE BUTTON -->
                <button onclick="window.history.back()"
                    class="absolute top-2 right-2 bg-black/60 hover:bg-black/80 text-white w-8 h-8 rounded-full flex items-center justify-center text-lg font-bold z-10">
                    ✕
                </button>

                <!-- IMAGE -->
                <img src="/images/uploads/<%= post.image %>" class="w-full h-[400px] object-cover rounded-lg">

            </div>

            <!-- Title -->
            <h1 class="text-2xl font-bold mt-4 text-zinc-800">
                <%= post.title %>
            </h1>

            <!-- Description -->
            <p class="text-zinc-600 mt-2">
                <%= post.description %>
            </p>

            <!-- User -->
            <p class="text-sm mt-3 text-zinc-500">
                Posted by
                <a href="/user/<%= post.user.username %>" class="hover:text-red-400">
                    @<%= post.user.username %>
                </a>
            </p>

            <!-- ACTION BUTTONS -->
            <div class="flex gap-3 mt-5">

                <!-- Download -->
                <a href="/images/uploads/<%= post.image %>" download
                    class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm">
                    Download
                </a>
                <form action="/like/<%= post._id %>" method="POST">
                    <button class="bg-pink-500 hover:bg-pink-600 text-white px-4 py-2 rounded-lg text-sm">
                        ❤️ <%= post.likes.length %>
                    </button>
                </form>

                <!-- ✅ DELETE ONLY FOR OWNER -->
                <% if (post.user._id.toString()===user._id.toString()) { %>
                    <form action="/post/delete/<%= post._id %>" method="POST"
                        onsubmit="return confirm('Delete this post?')">
                        <button type="submit"
                            class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg text-sm">
                            Delete
                        </button>
                    </form>
                    <% } %>

            </div>

        </div>

    </div>

    <% include ./partials/footer.ejs %>