<% include ./partials/header.ejs %>

       <div
              class="w-full min-h-screen bg-[url('https://images.unsplash.com/photo-1460574283810-2aab119d8511?w=500&auto=format&fit=crop&q=60')] bg-no-repeat bg-center bg-cover flex items-center justify-center px-4">

              <div class="w-full sm:w-3/4 md:w-1/2 lg:w-1/3 bg-white px-6 sm:px-10 py-8 rounded-3xl shadow-xl">

                     <h1 class="text-2xl sm:text-3xl text-center font-semibold text-zinc-700 mb-6">
                            Create an Account
                     </h1>

                     <% if (error && error.length> 0) { %>
                            <p class="bg-red-100 text-red-600 text-sm text-center py-2 rounded mb-4">
                                   <%= error[0] %>
                            </p>
                            <% } %>

                                   <form id="registerForm" action="/register" method="post" autocomplete="off">

                                          <input class="input" type="email" name="email" placeholder="Email" required>
                                          <input class="input" type="text" name="username" placeholder="Username"
                                                 required>
                                          <input class="input" type="text" name="fullname" placeholder="Full Name"
                                                 required>

                                          <input class="input" type="number" name="contact" placeholder="Contact">

                                          <!-- PASSWORD -->
                                          <div class="relative mt-3">
                                                 <input id="password" class="border-2 rounded-md w-full px-3 py-2 pr-10"
                                                        type="password" name="password" placeholder="Password" required>

                                                 <span class="absolute right-3 top-1/2 -translate-y-1/2 cursor-pointer"
                                                        onclick="togglePassword('password', this)">
                                                        👁
                                                 </span>
                                          </div>

                                          <!-- CONFIRM PASSWORD -->
                                          <div class="relative mt-3">
                                                 <input id="confirmPassword"
                                                        class="border-2 rounded-md w-full px-3 py-2 pr-10"
                                                        type="password" placeholder="Confirm Password" required>

                                                 <span class="absolute right-3 top-1/2 -translate-y-1/2 cursor-pointer"
                                                        onclick="togglePassword('confirmPassword', this)">
                                                        👁
                                                 </span>
                                          </div>

                                          <!-- MATCH MESSAGE -->
                                          <p id="matchMsg" class="text-sm mt-2 hidden"></p>
                                          <!-- ERROR -->
                                          <p id="matchError" class="text-red-500 text-sm mt-2 hidden">
                                                 Passwords do not match ❌
                                          </p>

                                          <input class="w-full px-3 py-2 mt-5 bg-red-600 hover:bg-red-700 transition text-white rounded-full cursor-pointer"
                                                 type="submit" value="Create Account">

                                   </form>

                                   <a class="mt-6 inline-block font-semibold text-sm text-zinc-500 text-center w-full hover:text-zinc-700"
                                          href="/">
                                          Already have an account?
                                   </a>

              </div>
       </div>

       <!-- 🔥 JS -->
      <script src="/javascripts/register.js"></script>

       <% include ./partials/footer.ejs %>