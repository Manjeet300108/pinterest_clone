<% include ./partials/header.ejs %>

<div
  class="w-full min-h-screen bg-[url('https://images.unsplash.com/photo-1505778489066-159c5f4a6c0f?w=500&auto=format&fit=crop&q=60')] bg-no-repeat bg-center bg-cover flex items-center justify-center px-4">

  <div class="w-full sm:w-3/4 md:w-1/2 lg:w-1/3 bg-white px-6 sm:px-10 py-8 rounded-3xl shadow-xl">

    <h1 class="text-2xl sm:text-3xl text-center font-semibold text-zinc-700 capitalize">
      Welcome to Pinterest
    </h1>

    <!-- 🔥 ERROR -->
    <% if (error && error.length > 0) { %>
      <p class="bg-red-100 text-red-600 mt-3 text-sm text-center py-2 rounded">
        <%= error[0] %>
      </p>
    <% } %>

    <form action="/login" method="post" class="mt-6" autocomplete="off">

      <input
        class="border-2 rounded-md w-full px-3 py-2 mt-3 focus:outline-none focus:ring-2 focus:ring-red-400"
        type="text"
        name="username"
        placeholder="Username"
        autocomplete="off"
        required>

      <!-- PASSWORD WITH EYE -->
      <div class="relative mt-3">
        <input
          id="loginPassword"
          class="border-2 rounded-md w-full px-3 py-2 pr-10 focus:outline-none focus:ring-2 focus:ring-red-400"
          type="password"
          name="password"
          placeholder="Password"
          autocomplete="new-password"
          required>

        <span onclick="toggleLoginPassword(this)"
              class="absolute right-3 top-2.5 cursor-pointer">
          👁
        </span>
      </div>

      <input
        class="w-full px-3 py-2 mt-4 bg-red-600 hover:bg-red-700 transition text-white rounded-full cursor-pointer"
        type="submit"
        value="Login">

      <p class="text-xs text-zinc-600 mt-6 text-center px-4">
        By continuing, you agree to Pinterest's Terms of Service and acknowledge you've read our Privacy Policy.
      </p>

    </form>

    <a class="mt-6 inline-block text-sm font-semibold text-zinc-500 text-center w-full hover:text-zinc-700"
       href="/register">
       Don't have an account?
    </a>

  </div>
</div>

<!-- 🔥 JS -->
<script>
  function toggleLoginPassword(el) {
    const input = document.getElementById("loginPassword");

    if (input.type === "password") {
      input.type = "text";
      el.textContent = "🙈";
    } else {
      input.type = "password";
      el.textContent = "👁";
    }
  }
</script>

<% include ./partials/footer.ejs %>