<% include ./partials/header.ejs %>

<div class="w-full min-h-screen bg-zinc-800 text-white px-4 md:px-10 py-8">

  <!-- USER INFO -->
  <div class="flex flex-col items-center">

    <div class="w-28 h-28 rounded-full overflow-hidden bg-zinc-200">
      <img src="/images/uploads/<%= user.profileImg %>" class="w-full h-full object-cover">
    </div>

    <h1 class="text-2xl font-bold mt-4">
      <%= user.fullname %>
    </h1>

    <p class="opacity-70">
      @<%= user.username %>
    </p>

  </div>

  <!-- POSTS GRID -->
  <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

    <% user.posts.forEach(function(post){ %>

      <div class="bg-zinc-700 p-2 rounded-lg">

        <!-- CLICK POST -->
        <a href="/post/<%= post._id %>">
          <div class="aspect-square overflow-hidden rounded">
            <img src="/images/uploads/<%= post.image %>" class="w-full h-full object-cover">
          </div>
        </a>

        <!-- LIKE BUTTON -->
        <form action="/like/<%= post._id %>" method="POST" class="mt-2">
          <button class="text-sm bg-pink-500 px-2 py-1 rounded">
            ❤️ <%= post.likes.length %>
          </button>
        </form>

      </div>

    <% }) %>

  </div>

</div>

<% include ./partials/footer.ejs %>